modules = ["nodejs-20", "web"]

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "vm"
run = ["sh", "-c", "npm install && node index.js"]

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Start application"

[[workflows.workflow]]
name = "Start application"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && node index.js"

[agent]
expertMode = true
